{
  "name": "hp-mis",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:student": "pnpm --filter student dev",
    "dev:portal": "pnpm --filter portal dev",
    "dev:public": "pnpm --filter public-web dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules .turbo"
  },
  "devDependencies": {
    "turbo": "^2.9.6",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=10"
  }
}
