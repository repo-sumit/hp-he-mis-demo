{
  "name": "hp-mis",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo run dev --parallel --filter=student --filter=portal",
    "dev:student": "pnpm --filter student dev",
    "dev:portal": "pnpm --filter portal dev",
    "build": "turbo run build --filter=student --filter=portal",
    "lint": "turbo run lint --filter=student --filter=portal",
    "typecheck": "turbo run typecheck --filter=student --filter=portal",
    "clean": "turbo run clean && rimraf node_modules .turbo"
  },
  "devDependencies": {
    "turbo": "^2.9.6",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=10"
  }
}
